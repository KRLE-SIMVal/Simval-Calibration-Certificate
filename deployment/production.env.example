# SIMVal production runtime environment example.
# Copy values into the approved host/service configuration.
# Do not store secrets or uncontrolled production paths in source control.

SIMVAL_DATABASE_PATH=C:\SIMVal\data\simval.sqlite3
SIMVAL_ARTIFACT_STORAGE_PATH=C:\SIMVal\artifacts
SIMVAL_RUNTIME_PROFILE=production
SIMVAL_ENABLED_DISCIPLINES=temperature
SIMVAL_AUTH_PROVIDER=entra_id_free
SIMVAL_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
SIMVAL_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
SIMVAL_ENTRA_AUDIENCE=00000000-0000-0000-0000-000000000000
SIMVAL_ENTRA_LOCAL_SESSION_HOURS=8
SIMVAL_HOSTING_MODEL=simval_internal_host
SIMVAL_REVIEWER_INDEPENDENCE_REQUIRED=true
